# Shrok — environment configuration
# Run `npm run setup` to configure interactively.

# ─── LLM Provider ─────────────────────────────────────────────────────────────

LLM_PROVIDER=              # anthropic | gemini | openai
LLM_PROVIDER_PRIORITY=     # comma-separated fallback order, e.g. anthropic,gemini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_OAUTH_ACCESS_TOKEN=
OPENAI_OAUTH_REFRESH_TOKEN=
OPENAI_OAUTH_EXPIRES_AT=

# ─── Channels ─────────────────────────────────────────────────────────────────

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=
WHATSAPP_ALLOWED_JID=  # e.g. 19175551234@s.whatsapp.net
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_CLIQ_CHAT_ID=

# ─── Web Search ───────────────────────────────────────────────────────────────

SEARCH_PROVIDER=           # tavily | brave
TAVILY_API_KEY=
BRAVE_API_KEY=

# ─── Webhooks ─────────────────────────────────────────────────────────────────

WEBHOOK_SECRET=

# ─── Dashboard ────────────────────────────────────────────────────────────────

DASHBOARD_PASSWORD_HASH=   # bcrypt hash — set via npm run setup

# ─── Advanced ─────────────────────────────────────────────────────────────────

# LOG_LEVEL=                 # debug | info | warn | error (default: info)
# WORKSPACE_PATH=            # override workspace location (default: ~/.shrok/workspace)
# DB_PATH=                   # override SQLite DB path (default: <workspace>/data/shrok.db)
# MCP_CONFIG_PATH=           # path to mcp.json for MCP server configs (default: ./mcp.json)
